{
  "name": "electrode-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "preview": "npm --workspace apps/web run preview",
    "build": "npm run build:packages && npm --workspace apps/web run build",
    "build:packages": "npm run schemas:assets && npm --workspace @electrode/flatbuffers run build && npm --workspace @electrode/sdk run build",
    "check": "npm run build:packages && npm --workspace apps/web run check",
    "bridge": "cargo run -p electrode-ground-bridge",
    "manual:bridge": "cargo run -p electrode-manual-control-bridge --bin electrode-manual-control-bridge --",
    "manual:dump": "cargo run -p electrode-manual-control-bridge --bin electrode-manual-control-dump --",
    "ppm:bridge": "cargo run -p electrode-ppm-bridge --bin electrode-ppm-bridge --",
    "schemas:assets": "node scripts/generate-log-schema-assets.mjs",
    "schemas:generate": "node scripts/generate-flatbuffers.mjs",
    "build:gcs": "cargo build && npm run build"
  }
}
