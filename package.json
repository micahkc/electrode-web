{
  "name": "electrode-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "preview": "npm --workspace apps/web run preview",
    "build": "npm run build:packages && npm --workspace apps/web run build",
    "build:packages": "npm --workspace @electrode/flatbuffers run build && npm --workspace @electrode/sdk run build",
    "check": "npm run build:packages && npm --workspace apps/web run check",
    "lint": "npm run lint:js && npm run lint:rust-files",
    "lint:js": "eslint .",
    "lint:rust-files": "node scripts/check-rust-file-lines.mjs",
    "test": "vitest run",
    "verify:pages": "node scripts/verify-pages-build.mjs",
    "ci": "npm run lint && npm run test && npm run check && npm run build && npm run verify:pages",
    "station": "npm run build && ELECTRODE_GCS_ZENOH_CONNECT=udp/192.168.10.2:7447 cargo run -p electrode-ground-station --",
    "ground-station": "ELECTRODE_GCS_ZENOH_CONNECT=udp/192.168.10.2:7447 cargo run -p electrode-ground-station --",
    "bridge": "cargo run -p electrode-ground-bridge",
    "sim:fake": "cargo run -p electrode-fake-sim --",
    "manual:bridge": "cargo run -p electrode-manual-control-bridge --bin electrode-manual-control-bridge --",
    "manual:dump": "cargo run -p electrode-manual-control-bridge --bin electrode-manual-control-dump --",
    "ppm:bridge": "cargo run -p electrode-ppm-bridge --bin electrode-ppm-bridge --",
    "build:gcs": "cargo build && npm run build"
  },
  "dependencies": {
    "@cognipilot/synapse-fbs": "^0.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
