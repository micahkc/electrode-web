namespace electrode.common;

enum Priority : ubyte {
  Low = 0,
  Normal = 1,
  High = 2,
  Critical = 3
}

table Header {
  sequence:ulong;
  source_time_ns:ulong;
  receive_time_ns:ulong;
  expire_time_ns:ulong;
  vehicle_id:string;
  schema_version:ushort;
  message_type:string;
  priority:Priority = Normal;
  stream_id:string;
}

